{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "{prisma/**,dist/**,node_modules/.prisma/**,node_modules/@prisma/client/**}",
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/v1/internal/cron/invoice-scheduler",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/v1/internal/cron/reminder-scheduler",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/v1/internal/cron/lease-expiry",
      "schedule": "30 1 * * *"
    },
    {
      "path": "/v1/internal/cron/subscription-check",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/v1/internal/cron/booking-expiry",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/v1/internal/cron/recurring-expenses",
      "schedule": "15 1 * * *"
    },
    {
      "path": "/v1/internal/cron/outbox-drain",
      "schedule": "0 4 * * *"
    }
  ]
}
